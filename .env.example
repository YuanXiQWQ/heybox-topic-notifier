# 最小可用配置
# 复制成本地 .env 或部署变量时，通常只需要保留这一段。
APP_LOCALE=zh-CN
HEYBOX_TOPIC_ID=12099
POLL_ENABLED=false
NOTIFIER_PROVIDER=disabled

# 本地运行
# Deno Deploy 不需要配置 PORT；本地启动如需改端口再取消注释。
# PORT=8000

# 轮询默认值
# 以下值都有代码默认值，只在需要改变新账号的初始轮询设置时配置。
# POLL_INTERVAL_MINUTES=1
# POLL_POST_LIMIT=20
# POLL_SORT=publishTime

# 小黑盒请求覆盖项
# 正常情况下使用内置默认值即可；接口异常或需要固定设备信息时再配置。
# HEYBOX_SIGNATURE_MODE=app
# HEYBOX_DEVICE_ID=
# HEYBOX_COOKIE=
# HEYBOX_USER_AGENT=

# 通知公共项
# NOTIFIER_PROVIDER 可选：disabled、webhook、email。
# NOTIFIER_DELIVERY_TIMEOUT_SECONDS=30

# Webhook 通知：自定义 Webhook
# NOTIFIER_PROVIDER=webhook
# NOTIFIER_WEBHOOK_SERVICE=custom
# NOTIFIER_WEBHOOK_URL=https://example.com/webhook

# Webhook 通知：PushPlus
# NOTIFIER_PROVIDER=webhook
# NOTIFIER_WEBHOOK_SERVICE=pushPlus
# NOTIFIER_PUSHPLUS_TOKEN=

# Webhook 通知：WxPusher
# NOTIFIER_PROVIDER=webhook
# NOTIFIER_WEBHOOK_SERVICE=wxPusher
# NOTIFIER_WXPUSHER_SPT=

# Webhook 通知：ServerChan
# NOTIFIER_PROVIDER=webhook
# NOTIFIER_WEBHOOK_SERVICE=serverChan
# NOTIFIER_SERVER_CHAN_SEND_KEY=

# 邮件通知：SMTP
# NOTIFIER_PROVIDER=email
# NOTIFIER_EMAIL_SERVICE=smtp
# NOTIFIER_EMAIL_ADDRESS=
# NOTIFIER_EMAIL_FROM=
# NOTIFIER_SMTP_HOST=smtp.example.com
# NOTIFIER_SMTP_PORT=465
# NOTIFIER_SMTP_SECURE=true
# NOTIFIER_SMTP_USERNAME=
# NOTIFIER_SMTP_PASSWORD=

# 邮件通知：HTTP API
# NOTIFIER_PROVIDER=email
# NOTIFIER_EMAIL_SERVICE=api
# NOTIFIER_EMAIL_ADDRESS=
# NOTIFIER_EMAIL_FROM=
# NOTIFIER_EMAIL_API_URL=https://example.com/mail
# NOTIFIER_EMAIL_API_TOKEN=

# 通知中转
# 只有把 PushPlus、WxPusher 或 ServerChan 指向自建中转 Worker 时才需要。
# NOTIFIER_PUSHPLUS_SEND_URL=https://<your-worker>.workers.dev/pushplus
# NOTIFIER_WXPUSHER_SEND_URL=https://<your-worker>.workers.dev/wxpusher
# NOTIFIER_SERVER_CHAN_SEND_URL=https://<your-worker>.workers.dev/serverchan
# NOTIFIER_RELAY_TOKEN=

# 出站安全白名单
# 默认只允许公网 HTTPS URL 和常见 SMTP 端口。仅在信任自建中转或固定邮件主机时配置。
# OUTBOUND_ALLOWED_HOSTS=relay.example.com,smtp.example.com
